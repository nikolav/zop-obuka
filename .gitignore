.vscode/
.idea/
*.swp
*.swo
*~
.workspace
*.sublime-workspace
*.sublime-project

# ================================
# Dependency Directories
# ================================

# Node.js / npm / yarn
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log
.pnpm-store/

# Python (if using Python for build tools)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
htmlcov/

# Ruby (if using Jekyll or similar)
.bundle/
Gemfile.lock
vendor/bundle/
vendor/ruby/

# ================================
# Build / Output Directories
# ================================

# Static site generators (Hugo, Jekyll, Gatsby, Next.js, etc.)
/public/
/dist/
/build/
/.cache/
/.next/
/out/
/_site/
/.jekyll-cache/
/.jekyll-metadata

# ================================
# Documentation Build Outputs
# ================================

