/docs/_build/
/docs/build/
/docs/site/
/docs/.docusaurus/
/docs/.vitepress/dist/
/docs/.vuepress/dist/
/docs/api/
/docs/coverage/

# ================================
# Environment & Configuration Files
# ================================

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# ================================
# Logs & Temporary Files
# ================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# ================================
# Test Coverage
# ================================

coverage/
.nyc_output/
coverage.lcov
test-results/
jest-coverage/

# ================================
# Misc / Safe to Ignore
# ================================

# Local configuration files (except templates)
*.local
*_local.*

# Backup files
*.bak
*.old
*.orig

# Archives (unless you want to track them)
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# ================================
# Docker / Container
# ================================

.dockerignore
Dockerfile.*.swp
.docker/
*.pid
*.pid.lock

# ================================
# Static App Specific
# ================================

# Static site assets (generated)
/assets/generated/
/static/generated/

# Image optimization cache
/.next/cache/
/gatsby-cache/
/.cache-loader/

# Service worker caches
sw.js
sw.*.js
workbox-*.js

# ================================
# Documentation Specific
# ================================

# Docs dependencies
/docs/node_modules/
/docs/.cache/
/docs/.parcel-cache/

# API generated docs
/docs/api/generated/
/docs/redoc-static.html

# ================================
# Git hooks
# ================================

.git/hooks/
.husky/_
.husky/*.local

